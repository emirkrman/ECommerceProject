@model List<ECommerceProject.Entity.Concrete.Category>

<h2>Kategoriler</h2>

<a asp-action="Create" class="btn btn-success mb-2">Yeni Kategori</a>

<table class="table">
    <thead>
        <tr>
            <th>Ad</th>
            <th>Açıklama</th>
            <th>Aktif</th>
            <th>İşlemler</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var category in Model.Where(c => c.ParentCategoryId == null))
        {
            <tr>
                <td><strong>@category.Name</strong></td>
                <td>@category.Description</td>
                <td>@category.IsActive</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@category.Id" class="btn btn-warning btn-sm">Düzenle</a>
                    <a asp-action="Delete" asp-route-id="@category.Id" class="btn btn-danger btn-sm">Sil</a>
                </td>
            </tr>

            @foreach (var subCategory in Model.Where(c => c.ParentCategoryId == category.Id))
            {
                <tr>
                    <td class="ps-5">&rarr; @subCategory.Name</td>
                    <td>@subCategory.Description</td>
                    <td>@subCategory.IsActive</td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@subCategory.Id" class="btn btn-warning btn-sm">Düzenle</a>
                        <a asp-action="Delete" asp-route-id="@subCategory.Id" class="btn btn-danger btn-sm">Sil</a>
                    </td>
                </tr>
            }
        }
    </tbody>
</table>
