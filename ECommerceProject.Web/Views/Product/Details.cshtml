@model ECommerceProject.Entity.Concrete.Product

@{
    ViewData["Title"] = Model.Name;
    var category = Model.Category;
    var parentCategory = category?.ParentCategory;
    var categoryText = parentCategory != null && category != null
        ? $"{parentCategory.Name} / {category.Name}"
        : category?.Name ?? "Kategori belirtilmemiÅŸ";
    var descriptionText = string.IsNullOrWhiteSpace(Model.Description)
        ? "Bu ürün için henüz açıklama eklenmemiş."
        : Model.Description;
    var stockText = Model.Stock > 0 ? "Stokta var" : "Stokta yok";
    var stockBadgeClass = Model.Stock > 0 ? "text-bg-success" : "text-bg-secondary";
    var ratingValue = Model.Rating;
    var fullStars = ratingValue.HasValue ? (int)Math.Floor(ratingValue.Value) : 0;
    var hasHalfStar = ratingValue.HasValue && ratingValue.Value - fullStars >= 0.5m;
    var emptyStars = ratingValue.HasValue ? 5 - fullStars - (hasHalfStar ? 1 : 0) : 5;
}

<div class="container py-4 py-lg-5">
    <div class="row g-4 align-items-start">
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm overflow-hidden">
                <img src="@(string.IsNullOrWhiteSpace(Model.ImageUrl) ? "https://placehold.co/900x700?text=Product" : Model.ImageUrl)"
                     alt="@Model.Name" class="img-fluid product-detail-image" />
            </div>
        </div>

        <div class="col-lg-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body p-4 p-lg-5">
                    <div class="text-muted small text-uppercase fw-semibold mb-2">@categoryText</div>

                    <h1 class="display-6 fw-bold mb-3">@Model.Name</h1>

                    <div class="d-flex align-items-center gap-3 flex-wrap mb-4">
                        <div class="fs-3 fw-bold">@Model.Price.ToString("C")</div>
                        <span class="badge rounded-pill @stockBadgeClass px-3 py-2">@stockText</span>
                    </div>

                    <div class="rating-box mb-4">
                        <div class="small text-muted mb-1">Puan</div>
                        <div class="d-flex align-items-center gap-2 flex-wrap">
                            <div class="rating-stars">
                                @if (ratingValue.HasValue)
                                {
                                    @for (int i = 0; i < fullStars; i++)
                                    {
                                        <span>★</span>
                                    }
                                    @if (hasHalfStar)
                                    {
                                        <span>☆</span>
                                    }
                                    @for (int i = 0; i < emptyStars; i++)
                                    {
                                        <span class="empty-star">☆</span>
                                    }
                                }
                                else
                                {
                                    <span class="empty-star">☆</span><span class="empty-star">☆</span><span
                                    class="empty-star">☆</span><span class="empty-star">☆</span><span
                                    class="empty-star">☆</span>
                                }
                            </div>
                            <span class="text-muted small">
                                @(ratingValue.HasValue ? $"{ratingValue.Value:0.0} / 5" : "Henüz puan bilgisi yok")
                            </span>
                        </div>
                    </div>

                    <div class="mb-4">
                        <h5 class="mb-3">Açıklama</h5>
                        <p class="text-muted mb-0">@descriptionText</p>
                    </div>

                    <div class="product-meta border-top pt-4">
                        <div class="meta-label">Kategori</div>
                        <div class="meta-value">@categoryText</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .product-detail-image {
        width: 100%;
        height: 100%;
        min-height: 420px;
        object-fit: cover;
        background: #f8f9fa;
    }

    .rating-box {
        padding: 1rem 1.1rem;
        border-radius: 0.75rem;
        background-color: #f8f9fa;
    }

    .rating-stars {
        letter-spacing: 0.15rem;
        color: #f0ad4e;
        font-size: 1rem;
    }

    .rating-stars .empty-star {
        color: #d0d4d9;
    }

    .meta-label {
        font-size: 0.8rem;
        color: #6c757d;
        margin-bottom: 0.2rem;
        text-transform: uppercase;
        letter-spacing: 0.04em;
    }

    .meta-value {
        font-weight: 600;
        color: #212529;
    }
</style>
