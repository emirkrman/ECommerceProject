@model List<ECommerceProject.Entity.Concrete.Product>

<h2>Products</h2>

<a asp-action="Create" class="btn btn-success mb-2">New Product</a>

<table class="table">
    <thead>
        <tr>
            <th>Name</th>
            <th>Price</th>
            <th>Stock</th>
            <th>Category</th>
            <th>Active</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Name</td>
                <td>@item.Price</td>
                <td>@item.Stock</td>
                <td>
                    @if (item.Category?.ParentCategory != null)
                    {
                        @item.Category.ParentCategory.Name
                        <span>/</span> <strong>@item.Category.Name</strong>
                    }
                    else
                    {
                        <strong>@item.Category?.Name</strong>
                    }
                </td>
                <td>@item.IsActive</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">Edit</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>