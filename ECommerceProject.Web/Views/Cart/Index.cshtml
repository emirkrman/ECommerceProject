@model List<ECommerceProject.Entity.Concrete.Cart>

@{
    ViewData["Title"] = "Sepetim";
    var cartTotal = Model
        .Where(item => item.Product != null)
        .Sum(item => item.Product!.Price * item.Quantity);
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center gap-3 mb-4">
        <div>
            <h2 class="mb-1">Sepetim</h2>
            <p class="text-muted mb-0">Sepetinizdeki urunleri buradan yonetebilirsiniz.</p>
        </div>

        @if (Model.Any())
        {
            <form asp-action="Clear" method="post" id="clearCartForm" class="js-cart-form js-cart-clear-form">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-outline-danger btn-sm">Sepeti Temizle</button>
            </form>
        }
    </div>

    <div id="cartMessage" class="alert d-none" role="alert"></div>

    @if (TempData["CartSuccess"] is string successMessage)
    {
        <div class="alert alert-success">@successMessage</div>
    }

    @if (TempData["CartError"] is string errorMessage)
    {
        <div class="alert alert-danger">@errorMessage</div>
    }

    <div id="cartEmptyState" class="card border-0 shadow-sm @(Model.Any() ? "d-none" : "")">
        <div class="card-body text-center py-5">
            <h5>Sepetiniz bos</h5>
            <p class="text-muted">Urunleri inceleyip sepetinize ekleyebilirsiniz.</p>
            <a asp-controller="Product" asp-action="List" class="btn btn-dark">Urunlere Git</a>
        </div>
    </div>

    <div id="cartContent" class="row g-4 @(!Model.Any() ? "d-none" : "")">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm">
                <div class="table-responsive">
                    <table class="table align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Urun</th>
                                <th class="text-center">Adet</th>
                                <th class="text-end">Ara Toplam</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody id="cartItems">
                            @foreach (var item in Model)
                            {
                                var product = item.Product;
                                var subtotal = product == null ? 0 : product.Price * item.Quantity;

                                <tr data-product-id="@item.ProductId">
                                    <td>
                                        <div class="d-flex align-items-center gap-3">
                                            <img src="@(string.IsNullOrWhiteSpace(product?.ImageUrl) ? "https://placehold.co/120x90?text=Product" : product.ImageUrl)"
                                                 alt="@product?.Name" class="cart-image" />
                                            <div>
                                                <a asp-controller="Product" asp-action="Details"
                                                       asp-route-id="@item.ProductId"
                                                       class="text-dark fw-semibold text-decoration-none">
                                                    @(product?.Name ?? "Urun bulunamadi")
                                                </a>
                                                <div class="text-muted small">@product?.Category?.Name</div>
                                                <div class="small">@((product?.Price ?? 0).ToString("C"))</div>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="text-center">
                                        <div class="d-inline-flex align-items-center quantity-stepper">
                                            <form asp-action="Update" method="post"
                                                  class="js-cart-form js-cart-quantity-form">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="productId" value="@item.ProductId" />
                                                <input type="hidden" name="quantity" value="@(item.Quantity - 1)"
                                                       data-quantity-target="decrease" />
                                                <button type="submit" class="btn btn-outline-dark btn-sm quantity-button"
                                                        aria-label="Adet azalt">
                                                    -
                                                </button>
                                            </form>

                                            <span class="quantity-value">@item.Quantity</span>

                                            <form asp-action="Update" method="post"
                                                  class="js-cart-form js-cart-quantity-form">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="productId" value="@item.ProductId" />
                                                <input type="hidden" name="quantity" value="@(item.Quantity + 1)"
                                                       data-quantity-target="increase" />
                                                <button type="submit" class="btn btn-outline-dark btn-sm quantity-button"
                                                        aria-label="Adet artir">
                                                    +
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                    <td class="text-end fw-semibold item-subtotal">@subtotal.ToString("C")</td>
                                    <td class="text-end">
                                        <form asp-action="Remove" method="post" class="js-cart-form js-cart-remove-form">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="productId" value="@item.ProductId" />
                                            <button type="submit" class="btn btn-outline-danger btn-sm">Kaldir</button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <h5 class="mb-3">Sepet Ozeti</h5>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Urun Toplami</span>
                        <strong class="cart-total">@cartTotal.ToString("C")</strong>
                    </div>
                    <hr />
                    <div class="d-flex justify-content-between fs-5 mb-3">
                        <span>Toplam</span>
                        <strong class="cart-total">@cartTotal.ToString("C")</strong>
                    </div>
                    <button type="button" class="btn btn-dark w-100" disabled>Siparise Gec</button>
                    <div class="text-muted small mt-2">Geliştirme aşamasında...</div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .cart-image {
        width: 72px;
        height: 54px;
        object-fit: cover;
        border-radius: 0.5rem;
        background: #f8f9fa;
    }

    .quantity-stepper {
        border: 1px solid #dee2e6;
        border-radius: 0.5rem;
        overflow: hidden;
        background: #fff;
    }

    .quantity-button {
        width: 34px;
        height: 34px;
        border: 0;
        border-radius: 0;
        font-weight: 700;
    }

    .quantity-value {
        min-width: 44px;
        height: 34px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-right: 1px solid #dee2e6;
        border-left: 1px solid #dee2e6;
        font-weight: 600;
    }
</style>

@section Scripts {
    <script>
        document.querySelectorAll('.js-cart-form').forEach((form) => {
            form.addEventListener('submit', async (event) => {
                event.preventDefault();

                const submitButton = event.submitter;
                if (submitButton) {
                    submitButton.disabled = true;
                }

                try {
                    const response = await fetch(form.action, {
                        method: 'POST',
                        headers: {
                            'X-Requested-With': 'XMLHttpRequest'
                        },
                        body: new FormData(form)
                    });

                    if (response.redirected) {
                        window.location.href = response.url;
                        return;
                    }

                    const data = await response.json();
                    showCartMessage(data.message, data.messageType);

                    if (!data.succeeded) {
                        return;
                    }

                    if (form.classList.contains('js-cart-clear-form')) {
                        showEmptyCart();
                        updateCartTotals(data.cartTotal);
                        return;
                    }

                    updateCartRow(data);
                    updateCartTotals(data.cartTotal);

                    if (data.isEmpty) {
                        showEmptyCart();
                    }
                } catch {
                    showCartMessage('Sepet guncellenirken bir hata olustu.', 'danger');
                } finally {
                    if (submitButton) {
                        submitButton.disabled = false;
                    }
                }
            });
        });

        function updateCartRow(data) {
            const row = document.querySelector(`[data-product-id="${data.productId}"]`);
            if (!row) {
                return;
            }

            if (data.removed) {
                row.remove();
                return;
            }

            row.querySelector('.quantity-value').textContent = data.quantity;
            row.querySelector('.item-subtotal').textContent = data.itemSubtotal;

            const decreaseInput = row.querySelector('[data-quantity-target="decrease"]');
            const increaseInput = row.querySelector('[data-quantity-target="increase"]');

            decreaseInput.value = data.quantity - 1;
            increaseInput.value = data.quantity + 1;
        }

        function updateCartTotals(cartTotal) {
            document.querySelectorAll('.cart-total').forEach((totalElement) => {
                totalElement.textContent = cartTotal;
            });
        }

        function showEmptyCart() {
            document.getElementById('cartContent').classList.add('d-none');
            document.getElementById('cartEmptyState').classList.remove('d-none');
            document.getElementById('clearCartForm')?.classList.add('d-none');
        }

        function showCartMessage(message, messageType) {
            if (!message) {
                return;
            }

            const messageElement = document.getElementById('cartMessage');
            messageElement.className = `alert alert-${messageType || 'info'}`;
            messageElement.textContent = message;
        }
    </script>
}
