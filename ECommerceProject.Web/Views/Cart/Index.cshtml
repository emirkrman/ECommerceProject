@model List<ECommerceProject.Entity.Concrete.Cart>

@{
    ViewData["Title"] = "Sepetim";
    var cartTotal = Model
        .Where(item => item.Product != null)
        .Sum(item => item.Product!.Price * item.Quantity);
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center gap-3 mb-4">
        <div>
            <h2 class="mb-1">Sepetim</h2>
            <p class="text-muted mb-0">Sepetinizdeki urunleri buradan yonetebilirsiniz.</p>
        </div>

        @if (Model.Any())
        {
            <form asp-action="Clear" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-outline-danger btn-sm">Sepeti Temizle</button>
            </form>
        }
    </div>

    @if (TempData["CartSuccess"] is string successMessage)
    {
        <div class="alert alert-success">@successMessage</div>
    }

    @if (TempData["CartError"] is string errorMessage)
    {
        <div class="alert alert-danger">@errorMessage</div>
    }

    @if (!Model.Any())
    {
        <div class="card border-0 shadow-sm">
            <div class="card-body text-center py-5">
                <h5>Sepetiniz bos</h5>
                <p class="text-muted">Urunleri inceleyip sepetinize ekleyebilirsiniz.</p>
                <a asp-controller="Product" asp-action="List" class="btn btn-dark">Urunlere Git</a>
            </div>
        </div>
    }
    else
    {
        <div class="row g-4">
            <div class="col-lg-8">
                <div class="card border-0 shadow-sm">
                    <div class="table-responsive">
                        <table class="table align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Urun</th>
                                    <th class="text-center">Adet</th>
                                    <th class="text-end">Ara Toplam</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    var product = item.Product;
                                    var subtotal = product == null ? 0 : product.Price * item.Quantity;

                                    <tr>
                                        <td>
                                            <div class="d-flex align-items-center gap-3">
                                                <img src="@(string.IsNullOrWhiteSpace(product?.ImageUrl) ? "https://placehold.co/120x90?text=Product" : product.ImageUrl)"
                                                     alt="@product?.Name" class="cart-image" />
                                                <div>
                                                    <a asp-controller="Product" asp-action="Details"
                                                           asp-route-id="@item.ProductId"
                                                           class="text-dark fw-semibold text-decoration-none">
                                                        @(product?.Name ?? "Urun bulunamadi")
                                                    </a>
                                                    <div class="text-muted small">@product?.Category?.Name</div>
                                                    <div class="small">@((product?.Price ?? 0).ToString("C"))</div>
                                                </div>
                                            </div>
                                        </td>
                                        <td class="text-center">
                                            <form asp-action="Update" method="post"
                                                  class="d-inline-flex align-items-center gap-2">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="productId" value="@item.ProductId" />
                                                <input type="number" name="quantity" value="@item.Quantity" min="0"
                                                       max="@(product?.Stock ?? item.Quantity)"
                                                       class="form-control form-control-sm quantity-input" />
                                                <button type="submit" class="btn btn-outline-dark btn-sm">Guncelle</button>
                                            </form>
                                        </td>
                                        <td class="text-end fw-semibold">@subtotal.ToString("C")</td>
                                        <td class="text-end">
                                            <form asp-action="Remove" method="post">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="productId" value="@item.ProductId" />
                                                <button type="submit" class="btn btn-outline-danger btn-sm">Kaldir</button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="card border-0 shadow-sm">
                    <div class="card-body">
                        <h5 class="mb-3">Sepet Ozeti</h5>
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted">Urun Toplami</span>
                            <strong>@cartTotal.ToString("C")</strong>
                        </div>
                        <hr />
                        <div class="d-flex justify-content-between fs-5 mb-3">
                            <span>Toplam</span>
                            <strong>@cartTotal.ToString("C")</strong>
                        </div>
                        <button type="button" class="btn btn-dark w-100" disabled>Siparise Gec</button>
                        <div class="text-muted small mt-2">Geliştirme aşamasında...</div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<style>
    .cart-image {
        width: 72px;
        height: 54px;
        object-fit: cover;
        border-radius: 0.5rem;
        background: #f8f9fa;
    }

    .quantity-input {
        width: 78px;
    }
</style>
