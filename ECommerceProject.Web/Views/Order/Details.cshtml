@model ECommerceProject.Web.ViewModels.Orders.OrderDetailsViewModel

@{
    ViewData["Title"] = $"Siparis #{Model.Id}";
    var status = GetStatusInfo(Model.Status);
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center gap-3 mb-4">
        <div>
            <h2 class="mb-1">Sipariş #@Model.Id</h2>
            <p class="text-muted mb-0">@Model.CreatedDate.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</p>
        </div>

        <a asp-action="Index" class="btn btn-outline-dark">Siparişlerime Dön</a>
    </div>

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm">
                <div class="table-responsive">
                    <table class="table align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Ürün</th>
                                <th class="text-center">Adet</th>
                                <th class="text-end">Birim Fiyat</th>
                                <th class="text-end">Ara Toplam</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.Items)
                            {
                                <tr>
                                    <td>
                                        <a asp-controller="Product" asp-action="Details"
                                           asp-route-id="@item.ProductId"
                                           class="text-dark fw-semibold text-decoration-none">
                                            @item.ProductName
                                        </a>
                                    </td>
                                    <td class="text-center">@item.Quantity</td>
                                    <td class="text-end">@item.UnitPrice.ToString("C")</td>
                                    <td class="text-end fw-semibold">@item.Subtotal.ToString("C")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-body">
                    <h5 class="mb-3">Sipariş Özeti</h5>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Durum</span>
                        <span class="badge text-bg-@status.BadgeClass">@status.Text</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Toplam</span>
                        <strong>@Model.TotalAmount.ToString("C")</strong>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(Model.PaymentCardLastFour))
                    {
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted">Kart</span>
                            <span>**** @Model.PaymentCardLastFour</span>
                        </div>
                    }
                    @if (!string.IsNullOrWhiteSpace(Model.PaymentMessage))
                    {
                        <hr />
                        <div class="small text-muted">@Model.PaymentMessage</div>
                    }
                </div>
            </div>

            @if (Model.Address != null)
            {
                <div class="card border-0 shadow-sm">
                    <div class="card-body">
                        <h5 class="mb-3">Teslimat Adresi</h5>
                        <div class="fw-semibold">@Model.Address.Title</div>
                        <div>@Model.Address.FullName</div>
                        <div>@Model.Address.PhoneNumber</div>
                        <div>@Model.Address.City / @Model.Address.District</div>
                        <div class="text-muted mt-2">@Model.Address.AddressLine</div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@functions {
    private static (string Text, string BadgeClass) GetStatusInfo(OrderStatus status)
    {
        return status switch
        {
            OrderStatus.PaymentSucceeded => ("Ödeme Başarılı", "success"),
            OrderStatus.PaymentFailed => ("Ödeme Başarısız", "danger"),
            _ => ("Beklemede", "secondary")
        };
    }
}
