@model ErrorViewModel
@{
    ViewData["Title"] = "Hata";
}

<h1 class="text-danger">Hata</h1>
<h2 class="text-danger">İstek işlenirken beklenmeyen bir sorun oluştu.</h2>

@if (Model.ShowRequestId)
{
    <p>
        <strong>İstek Kimliği:</strong> <code>@Model.RequestId</code>
    </p>
}

<h3>Geliştirme Modu</h3>
<p>
    <strong>Development</strong> ortamı etkin olduğunda hata hakkında daha ayrıntılı bilgi görüntülenir.
</p>
<p>
    <strong>Canlı ortamlarda Development modu açık olmamalıdır.</strong>
    Bu durum son kullanıcılara hassas hata ayrıntılarının gösterilmesine neden olabilir.
</p>
