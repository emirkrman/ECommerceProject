<!DOCTYPE html>
<html lang="tr">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ECommerce</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>

<body>
    @{
        var navCategories = ViewBag.NavCategories as IEnumerable<ECommerceProject.Entity.Concrete.Category>;
    }

    <header>
        <nav class="navbar navbar-dark bg-dark">
            <div class="container position-relative">

                <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                    ECommerce
                </a>

                <!-- ORTA ARAMA -->
                <form asp-controller="Product" asp-action="List" method="get"
                      class="position-absolute start-50 translate-middle-x w-50">
                    <div class="input-group">
                        <input type="text" name="search" class="form-control" placeholder="Ürün ara..." />
                        <button class="btn btn-light" type="submit">Ara</button>
                    </div>
                </form>

                <div class="d-flex align-items-center gap-2">
                    @if (User.IsInRole("Admin"))
                    {
                        <a class="btn btn-outline-light btn-sm" asp-controller="Home" asp-action="Admin">
                            Admin
                        </a>
                    }

                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <span class="text-white-50 small">Merhaba, @User.Identity.Name</span>
                        <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-outline-light btn-sm">Cikis</button>
                        </form>
                    }
                    else
                    {
                        <a class="btn btn-outline-light btn-sm" asp-controller="Account" asp-action="Login">Giris</a>
                        <a class="btn btn-light btn-sm" asp-controller="Account" asp-action="Register">Kayit Ol</a>
                    }
                </div>

            </div>
        </nav>

        <!-- KATEGORİ BAR -->
        <div class="category-bar border-bottom py-2">
            <div class="container category-bar-inner">

                @if (navCategories != null)
                {
                    foreach (var category in navCategories)
                    {
                        <div class="dropdown category-dropdown">

                            <a class="btn btn-sm category-trigger dropdown-toggle" asp-controller="Product" asp-action="List"
                               asp-route-categoryId="@category.Id">
                                @category.Name
                            </a>

                            @if (category.SubCategories?.Any() == true)
                            {
                                <ul class="dropdown-menu category-menu">
                                    @foreach (var sub in category.SubCategories)
                                    {
                                        <li>
                                            <a class="dropdown-item category-item" asp-controller="Product" asp-action="List"
                                               asp-route-categoryId="@sub.Id">
                                                @sub.Name
                                            </a>
                                        </li>
                                    }
                                </ul>
                            }

                        </div>
                    }
                }

            </div>
        </div>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - ECommerceProject.Web - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>
