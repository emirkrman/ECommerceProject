@{
    ViewData["Title"] = "Home";
}

<div class="text-center mb-5">
    <h1 class="display-5">E-Commerce Admin Panel</h1>
    <p>Hızlı erişim menüsü</p>
</div>

<div class="row justify-content-center">

    <div class="col-md-4 mb-3">
        <div class="card shadow h-100">
            <div class="card-body text-center d-flex flex-column">
                <h4>Categories</h4>
                <p>Kategori işlemleri</p>

                <div class="mt-auto w-100">
                    <a asp-controller="Category" asp-action="Index" class="btn btn-primary w-100 mb-2">
                        Listele
                    </a>

                    <a asp-controller="Category" asp-action="Create" class="btn btn-success w-100">
                        Yeni Ekle
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-4 mb-3">
        <div class="card shadow h-100">
            <div class="card-body text-center d-flex flex-column">
                <h4>Products</h4>
                <p>Ürün işlemleri</p>

                <div class="mt-auto w-100">
                    <a asp-controller="Product" asp-action="Index" class="btn btn-primary w-100 mb-2">
                        Listele
                    </a>

                    <a asp-controller="Product" asp-action="Create" class="btn btn-success w-100">
                        Yeni Ekle
                    </a>
                </div>
            </div>
        </div>
    </div>

</div>